# Environment variables for Distributed Sync System

# Node Configuration
NODE_ID=node_1
NODE_HOST=0.0.0.0
NODE_PORT=8000

# Other Nodes (comma separated URLs)
PEERS=http://node_2:8000,http://node_3:8000

# Redis Configuration (Optional, depending on usage)
REDIS_HOST=redis
REDIS_PORT=6379

# Raft Configuration
ELECTION_TIMEOUT_MIN=150
ELECTION_TIMEOUT_MAX=300
HEARTBEAT_INTERVAL=50
